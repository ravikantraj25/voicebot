# ─── Twilio Credentials ───────────────────────
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_PHONE_NUMBER=your_twilio_phone_number_here

# ─── MongoDB ──────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/voice-order-bot

# ─── Server ──────────────────────────────────
PORT=5000

# ─── Base URL (for Twilio webhooks) ──────────
BASE_URL=https://your-ngrok-url.ngrok-free.dev

# ─── Groq AI (LLM for summaries & search) ────
GROQ_API_KEY=your_groq_api_key_here

# ─── Twilio WhatsApp Sandbox ─────────────────
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# ─── Speech & Emotion AI ───────────────────────
SARVAM_API_KEY=your_sarvam_api_key_here
DEEPGRAM_API_KEY=your_deepgram_api_key_here
HUME_API_KEY=your_hume_api_key_here
HUME_SECRET_KEY=your_hume_secret_key_here

# ─── Exotel Credentials ───────────────────────
EXOTEL_ACCOUNT_SID=your_exotel_account_sid_here
EXOTEL_API_KEY=your_exotel_api_key_here
EXOTEL_API_TOKEN=your_exotel_api_token_here
EXOTEL_SUBDOMAIN=api.exotel.com
EXOTEL_PHONE_NUMBER=your_exotel_phone_number_here
